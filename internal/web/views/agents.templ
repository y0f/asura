package views

import (
	"fmt"
	"time"

	"github.com/y0f/asura/internal/storage"
)

type AgentListParams struct {
	LayoutParams
	Agents []*storage.Agent
}

func agentOnline(a *storage.Agent) bool {
	return a.LastHeartbeat != nil && time.Since(*a.LastHeartbeat) < 2*time.Minute
}

templ AgentListPage(p AgentListParams) {
	@Layout(p.LayoutParams) {
		<div x-data="{showForm: false}">
			<div class="flex items-center justify-end mb-5">
				if p.Perms["monitors.write"] {
					<button @click="showForm = true" class="btn-primary btn-press">
						<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14m7-7H5"></path></svg>
						New Agent
					</button>
				}
			</div>
			if len(p.Agents) > 0 {
				<div class="panel">
					<table class="w-full">
						<thead>
							<tr class="border-b border-line text-left">
								<th class="th">Name</th>
								<th class="th">Location</th>
								<th class="th">Status</th>
								<th class="th">Last Seen</th>
								<th class="th text-right">Actions</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-line">
							for _, a := range p.Agents {
								<tr class="hover:bg-surface-200/20 transition-colors">
									<td class="px-4 py-3 text-sm text-white font-medium">{ a.Name }</td>
									<td class="px-4 py-3 text-xs text-muted">
										if a.Location != "" {
											{ a.Location }
										} else {
											<span class="text-muted/30">-</span>
										}
									</td>
									<td class="px-4 py-3">
										if agentOnline(a) {
											<span class="badge badge-emerald inline-flex items-center gap-1.5">
												<span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-dot"></span>
												online
											</span>
										} else if a.LastHeartbeat != nil {
											<span class="badge badge-red">offline</span>
										} else {
											<span class="badge badge-zinc">never connected</span>
										}
									</td>
									<td class="px-4 py-3 text-xs text-muted tabular-nums">
										if a.LastHeartbeat != nil {
											{ TimeAgo(*a.LastHeartbeat) }
										} else {
											<span class="text-muted/30">-</span>
										}
									</td>
									<td class="px-4 py-3 text-right">
										if p.Perms["monitors.write"] {
											@DeleteButton(fmt.Sprintf("%s/agents/%d/delete", p.BasePath, a.ID), "Delete this agent? Monitors checked by it will fall back to central checks.")
										}
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			} else {
				if p.Perms["monitors.write"] {
					@EmptyStateModal("No agents yet", "showForm = true", "New Agent")
				} else {
					@EmptyState("No agents yet", "", "")
				}
				<div class="mt-4 card card-pad">
					<p class="text-xs text-muted-light mb-2">Agents run checks from remote locations and report back to this server.</p>
					<p class="text-xs text-muted">Create an agent, then run the agent binary on a remote server:</p>
					<pre class="mt-2 text-2xs text-muted-light bg-surface-200 rounded-control px-3 py-2 font-mono overflow-x-auto">asura-agent --server https://your-server.com --token &lt;agent-token&gt;</pre>
				</div>
			}
			@FormModal("showForm", "max-w-sm", "'New Agent'") {
				<form method="POST" action={ templ.SafeURL(p.BasePath + "/agents") } class="space-y-3">
					<div>
						<label class="form-label" for="name">Name</label>
						<input id="name" type="text" name="name" required placeholder="US-East, EU-West, etc." class="form-input"/>
					</div>
					<div>
						<label class="form-label" for="location">Location</label>
						<input id="location" type="text" name="location" placeholder="New York, Frankfurt, etc." class="form-input"/>
					</div>
					<div class="flex items-center gap-3 pt-1">
						<button type="submit" class="btn-primary btn-press">Create</button>
						<button type="button" @click="showForm = false" class="btn-secondary btn-press">Cancel</button>
					</div>
				</form>
			}
		</div>
	}
}
