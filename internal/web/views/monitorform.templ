package views

import (
	"fmt"
	"strings"

	"github.com/y0f/asura/internal/storage"
)

type MonitorFormParams struct {
	LayoutParams
	Monitor              *storage.Monitor
	HTTP                 storage.HTTPSettings
	TCP                  storage.TCPSettings
	DNS                  storage.DNSSettings
	TLS                  storage.TLSSettings
	WS                   storage.WebSocketSettings
	Cmd                  storage.CommandSettings
	Docker               storage.DockerSettings
	Domain               storage.DomainSettings
	GRPC                 storage.GRPCSettings
	MQTT                 storage.MQTTSettings
	SMTP                 storage.SMTPSettings
	SSH                  storage.SSHSettings
	Redis                storage.RedisSettings
	PostgreSQL           storage.PostgreSQLSettings
	UDP                  storage.UDPSettings
	MultiStep            storage.MultiStepHTTPSettings
	FollowRedirects      bool
	MaxRedirects         int
	HeadersJSON          string
	WsHeadersJSON        string
	AssertionsJSON       string
	SettingsJSON         string
	AssertionsRaw        string
	Groups               []*storage.MonitorGroup
	NotificationChannels []*storage.NotificationChannel
	SelectedChannelIDs   []int64
	Proxies              []*storage.Proxy
	EscalationPolicies   []*storage.EscalationPolicy
	AllTags              []*storage.Tag
	SelectedTags         []storage.MonitorTag
}

func (p MonitorFormParams) isTagSelected(tagID int64) bool {
	for _, t := range p.SelectedTags {
		if t.TagID == tagID {
			return true
		}
	}
	return false
}

func (p MonitorFormParams) tagValue(tagID int64) string {
	for _, t := range p.SelectedTags {
		if t.TagID == tagID {
			return t.Value
		}
	}
	return ""
}

func (p MonitorFormParams) cmdArgsStr() string {
	return strings.Join(p.Cmd.Args, ", ")
}

func (p MonitorFormParams) monitorTypeOrDefault() string {
	if p.Monitor.Type != "" {
		return p.Monitor.Type
	}
	return "http"
}

func (p MonitorFormParams) httpMethodOrDefault() string {
	if p.HTTP.Method != "" {
		return p.HTTP.Method
	}
	return "GET"
}

func (p MonitorFormParams) mtlsEnabled() bool {
	return p.HTTP.MTLSEnabled
}

func monitorFormXData(monType, httpMethod, authMethod, headersJSON, wsHeadersJSON, conditionsJSON string, mtlsEnabled bool) string {
	mtlsVal := "false"
	if mtlsEnabled {
		mtlsVal = "true"
	}
	return `{
    monitorType: '` + JSEscapeString(monType) + `',
    advancedSettings: false,
    advancedAssertions: false,
    httpHeaders: ` + headersJSON + `,
    wsHeaders: ` + wsHeadersJSON + `,
    conditions: ` + conditionsJSON + `,
    httpMethod: '` + JSEscapeString(httpMethod) + `',
    authMethod: '` + JSEscapeString(authMethod) + `',
    mtlsEnabled: ` + mtlsVal + `,
    newCond() { return {type:'status_code',operator:'eq',target:'',value:'',degraded:false}; },
    addGroup() { this.conditions.groups.push({operator:'and',conditions:[this.newCond()]}); },
    operatorsFor(type) {
        switch(type) {
            case 'status_code': case 'response_time': case 'cert_expiry':
                return [['eq','='],['neq','!='],['gt','>'],['lt','<'],['gte','>='],['lte','<=']];
            case 'body_contains':
                return [['contains','contains'],['not_contains','not contains']];
            case 'body_regex':
                return [['matches','matches'],['not_matches','not matches']];
            case 'json_path':
                return [['eq','='],['neq','!='],['gt','>'],['lt','<'],['contains','contains'],['exists','exists']];
            case 'header':
                return [['eq','='],['neq','!='],['contains','contains'],['exists','exists']];
            case 'dns_record':
                return [['contains','contains'],['eq','=']];
            default:
                return [['eq','='],['neq','!=']];
        }
    },
    needsTarget(type) { return type === 'json_path' || type === 'header'; },
    needsValue(op) { return op !== 'exists'; }
}`
}

func tagSelectorData(p MonitorFormParams) string {
	var b strings.Builder
	b.WriteString("{tags:[")
	for i, tag := range p.AllTags {
		if i > 0 {
			b.WriteByte(',')
		}
		fmt.Fprintf(&b, "{id:%d,name:'%s',color:'%s',on:%v,val:'%s'}",
			tag.ID, JSEscapeString(tag.Name), JSEscapeString(tag.Color),
			p.isTagSelected(tag.ID), JSEscapeString(p.tagValue(tag.ID)))
	}
	b.WriteString("],toggleTag(i){this.tags[i].on=!this.tags[i].on;if(!this.tags[i].on)this.tags[i].val=''}}")
	return b.String()
}

func advancedSectionData(p MonitorFormParams) string {
	show := "false"
	if p.Monitor.ID != 0 {
		hasGroup := p.Monitor.GroupID != nil
		hasProxy := p.Monitor.ProxyID != nil
		hasTags := len(p.SelectedTags) > 0
		hasChannels := len(p.SelectedChannelIDs) > 0
		hasEscalation := p.Monitor.EscalationPolicyID != nil
		hasSLA := p.Monitor.SLATarget != 0
		hasAnomaly := p.Monitor.AnomalySensitivity != "" && p.Monitor.AnomalySensitivity != "off"
		hasResend := p.Monitor.ResendInterval != 0
		hasTrack := p.Monitor.TrackChanges
		hasUpside := p.Monitor.UpsideDown
		hasAgentOff := !p.Monitor.AgentEnabled
		if hasGroup || hasProxy || hasTags || hasChannels || hasEscalation || hasSLA || hasAnomaly || hasResend || hasTrack || hasUpside || hasAgentOff {
			show = "true"
		}
	}
	return "{showAdvanced: " + show + "}"
}

func intOrDefault(v, def int) string {
	if v != 0 {
		return fmt.Sprint(v)
	}
	return fmt.Sprint(def)
}

templ MonitorFormPage(p MonitorFormParams) {
	@Layout(p.LayoutParams) {
		<div x-cloak x-data={ monitorFormXData(p.monitorTypeOrDefault(), p.httpMethodOrDefault(), p.HTTP.AuthMethod, p.HeadersJSON, p.WsHeadersJSON, p.AssertionsJSON, p.mtlsEnabled()) }>
			<form method="POST"
				if p.Monitor.ID != 0 {
					action={ templ.SafeURL(fmt.Sprintf("%s/monitors/%d", p.BasePath, p.Monitor.ID)) }
				} else {
					action={ templ.SafeURL(p.BasePath + "/monitors") }
				}
				class="max-w-3xl mx-auto space-y-4 pb-28 md:pb-4">
				<div class="card card-pad">
					<h2 class="text-sm font-semibold text-white mb-4">General</h2>
					<div class="space-y-4">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							<div>
								<label class="form-label" for="name">Name</label>
								<input id="name" type="text" name="name" value={ p.Monitor.Name } required class="form-input" placeholder="My Website"/>
							</div>
							<div>
								<label class="form-label" for="type">Type</label>
								<select id="type" name="type" x-model="monitorType" class="form-select">
									<optgroup label="Network">
										<option value="http">HTTP(S)</option>
										<option value="http_multi">HTTP Multi-Step</option>
										<option value="tcp">TCP Port</option>
										<option value="icmp">Ping (ICMP)</option>
										<option value="dns">DNS Lookup</option>
										<option value="smtp">SMTP Mail Server</option>
										<option value="ssh">SSH Server</option>
									</optgroup>
									<optgroup label="Security">
										<option value="tls">TLS Certificate</option>
										<option value="domain">Domain Expiry</option>
									</optgroup>
									<optgroup label="Database">
										<option value="redis">Redis</option>
										<option value="postgresql">PostgreSQL</option>
									</optgroup>
									<optgroup label="Application">
										<option value="websocket">WebSocket</option>
										<option value="grpc">gRPC Health</option>
										<option value="mqtt">MQTT Broker</option>
										<option value="udp">UDP</option>
										<option value="docker">Docker Container</option>
										<option value="command">Command / Script</option>
									</optgroup>
									<optgroup label="Passive">
										<option value="heartbeat">Heartbeat (push)</option>
										<option value="manual">Manual Status</option>
									</optgroup>
								</select>
							</div>
						</div>
						<div x-show="monitorType !== 'heartbeat' && monitorType !== 'manual'" x-cloak>
							<label class="form-label" for="target" x-text="monitorType === 'docker' ? 'Container Name / ID' : 'Target'">Target</label>
							<input id="target" type="text" name="target" value={ p.Monitor.Target } :placeholder="{http:'https://example.com', tcp:'host:port', dns:'example.com', icmp:'8.8.8.8', tls:'example.com:443', websocket:'wss://example.com/ws', command:'/usr/bin/check', docker:'container-name', domain:'example.com', grpc:'host:port', mqtt:'broker:1883'}[monitorType] || 'https://example.com'" class="form-input"/>
						</div>
						<div>
							<label class="form-label" for="description">Description <span class="text-muted font-normal">(optional)</span></label>
							<textarea id="description" name="description" rows="2" maxlength="5000" placeholder="Runbook notes, context, links…" class="form-input resize-y">{ p.Monitor.Description }</textarea>
						</div>
					</div>
				</div>
				<div x-show="monitorType !== 'heartbeat' && monitorType !== 'manual'" x-cloak>
					<div class="card card-pad">
						<h2 class="text-sm font-semibold text-white mb-4">Check Schedule</h2>
						<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
							<div>
								<label class="form-label" for="interval">Check every</label>
								<div class="relative">
									<input id="interval" type="number" name="interval" value={ intOrDefault(p.Monitor.Interval, 60) } min="5" max="86400" class="form-input tabular-nums pr-10"/>
									<span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-xs text-muted-light">sec</span>
								</div>
							</div>
							<div>
								<label class="form-label" for="timeout">Timeout after</label>
								<div class="relative">
									<input id="timeout" type="number" name="timeout" value={ intOrDefault(p.Monitor.Timeout, 10) } min="1" max="300" class="form-input tabular-nums pr-10"/>
									<span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-xs text-muted-light">sec</span>
								</div>
							</div>
							<div>
								<label class="form-label" for="failure_threshold">Failures before alert</label>
								<input id="failure_threshold" type="number" name="failure_threshold" value={ intOrDefault(p.Monitor.FailureThreshold, 3) } min="1" class="form-input tabular-nums"/>
							</div>
							<div>
								<label class="form-label" for="success_threshold">Successes to recover</label>
								<input id="success_threshold" type="number" name="success_threshold" value={ intOrDefault(p.Monitor.SuccessThreshold, 1) } min="1" class="form-input tabular-nums"/>
							</div>
						</div>
					</div>
				</div>
				<div class="card card-pad" x-show="monitorType !== 'heartbeat' && monitorType !== 'icmp' && monitorType !== 'manual'" x-cloak>
					<div class="flex items-center justify-between mb-4">
						<h2 class="text-sm font-semibold text-white">Settings</h2>
						<button type="button" @click="advancedSettings = !advancedSettings" class="text-2xs text-brand hover:text-brand/80 transition-colors rounded-control px-1 py-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50">
							<span x-text="advancedSettings ? 'Form Mode' : 'Advanced (JSON)'"></span>
						</button>
					</div>
					<input type="hidden" name="settings_mode" :value="advancedSettings ? 'json' : 'form'"/>
					<div x-show="advancedSettings" x-cloak>
						<textarea name="settings_json" rows="8" placeholder="{}" class="form-input font-mono resize-y">{ p.SettingsJSON }</textarea>
					</div>
					<div x-show="!advancedSettings" class="space-y-4">
						@monitorHTTPSettings(p)
						@monitorTCPSettings(p)
						@monitorDNSSettings(p)
						@monitorTLSSettings(p)
						@monitorWSSettings(p)
						@monitorCommandSettings(p)
						@monitorDockerSettings(p)
						@monitorDomainSettings(p)
						@monitorGRPCSettings(p)
						@monitorMQTTSettings(p)
						@monitorSMTPSettings(p)
						@monitorSSHSettings(p)
						@monitorRedisSettings(p)
						@monitorPostgreSQLSettings(p)
						@monitorUDPSettings(p)
					</div>
				</div>
				@monitorAssertions(p)
				<div x-data={ advancedSectionData(p) }>
					<button type="button" @click="showAdvanced = !showAdvanced" :aria-expanded="showAdvanced ? 'true' : 'false'" aria-controls="routing-behavior-panel" aria-label="Toggle routing and behavior settings" class="flex items-center gap-2 w-full text-left px-2 py-2 rounded-control border-t border-line group cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50">
						<span class="text-sm font-medium text-muted-light group-hover:text-white transition-colors">Routing &amp; behavior</span>
						<svg aria-hidden="true" class="w-4 h-4 text-muted-light group-hover:text-white transition-transform" :class="showAdvanced && 'rotate-90'" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
					</button>
					<div id="routing-behavior-panel" x-show="showAdvanced" x-cloak class="mt-4">
						<div class="card card-pad">
							<div class="space-y-4">
								if len(p.Groups) > 0 {
									<div>
										<label class="form-label" for="group_id">Group</label>
										<select id="group_id" name="group_id" class="form-select">
											<option value="">No group</option>
											for _, g := range p.Groups {
												<option value={ fmt.Sprint(g.ID) }
													if p.Monitor.GroupID != nil && *p.Monitor.GroupID == g.ID {
														selected
													}>{ g.Name }</option>
											}
										</select>
									</div>
								}
								<div>
									<label class="form-label">Tags</label>
									if len(p.AllTags) > 0 {
										<div x-data={ tagSelectorData(p) }>
											<div class="flex flex-wrap gap-1.5">
												for i, tag := range p.AllTags {
													<button type="button"
														@click={ fmt.Sprintf("toggleTag(%d)", i) }
														:class={ fmt.Sprintf("tags[%d].on ? 'border-brand/30 bg-brand/[0.06]' : 'border-line hover:border-line-light'", i) }
														class="inline-flex items-center gap-1 rounded border px-1.5 py-0.5 text-2xs transition-colors cursor-pointer select-none">
														<span class="w-1.5 h-1.5 rounded-full shrink-0" style={ "background-color: " + tag.Color }></span>
														<span :class={ fmt.Sprintf("tags[%d].on ? 'text-white' : 'text-muted-light'", i) }>{ tag.Name }</span>
													</button>
												}
											</div>
											<template x-if="tags.some(t => t.on)">
												<div class="mt-3 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
													<template x-for="(t, i) in tags" :key="t.id">
														<template x-if="t.on">
															<div class="flex items-center gap-2 rounded border border-line px-3 py-2">
																<input type="hidden" name="tag_ids[]" :value="t.id"/>
																<span class="w-1.5 h-1.5 rounded-full shrink-0" :style="'background-color:' + t.color"></span>
																<span class="text-2xs text-muted-light shrink-0" x-text="t.name"></span>
																<input type="text" name="tag_values[]" :value="t.val" @input="t.val = $event.target.value" placeholder="value (optional)"
																	class="form-input py-1 text-xs flex-1 min-w-0"/>
															</div>
														</template>
													</template>
												</div>
											</template>
										</div>
									} else {
										<p class="text-xs text-muted">No tags yet. <a href={ templ.SafeURL(p.BasePath + "/tags") } class="text-brand hover:text-brand/80 transition-colors">Create tags</a> to label monitors.</p>
									}
								</div>
								if len(p.Proxies) > 0 {
									<div>
										<label class="form-label" for="proxy_id">Proxy</label>
										<select id="proxy_id" name="proxy_id" class="form-select">
											<option value="">No proxy</option>
											for _, px := range p.Proxies {
												<option value={ fmt.Sprint(px.ID) }
													if p.Monitor.ProxyID != nil && *p.Monitor.ProxyID == px.ID {
														selected
													}>{ fmt.Sprintf("%s (%s://%s:%d)", px.Name, px.Protocol, px.Host, px.Port) }</option>
											}
										</select>
									</div>
								}
								if len(p.NotificationChannels) > 0 {
									<div>
										<label class="form-label">Notification Channels</label>
										<p class="text-2xs text-muted mb-2">Leave all unchecked to use all channels.</p>
										<div class="flex flex-wrap gap-1.5">
											for _, ch := range p.NotificationChannels {
												<label class="inline-flex items-center gap-1 rounded border px-1.5 py-0.5 text-2xs transition-colors cursor-pointer select-none has-checked:border-brand/30 has-checked:bg-brand/[0.06] border-line hover:border-line-light">
													<input type="checkbox" name="notification_channel_ids[]" value={ fmt.Sprint(ch.ID) }
														if InSlice(ch.ID, p.SelectedChannelIDs) {
															checked
														}
														class="hidden"/>
													<span class="text-muted-light">{ ch.Name }</span>
													<span class="text-muted">({ ch.Type })</span>
												</label>
											}
										</div>
									</div>
								}
								if len(p.EscalationPolicies) > 0 {
									<div>
										<label class="form-label" for="escalation_policy_id">Escalation Policy</label>
										<select id="escalation_policy_id" name="escalation_policy_id" class="form-select">
											<option value="">None</option>
											for _, ep := range p.EscalationPolicies {
												<option value={ fmt.Sprint(ep.ID) }
													if p.Monitor.EscalationPolicyID != nil && *p.Monitor.EscalationPolicyID == ep.ID {
														selected
													}>{ fmt.Sprintf("%s (%d steps)", ep.Name, len(ep.Steps)) }</option>
											}
										</select>
									</div>
								}
								<div>
									<label class="form-label" for="sla_target">SLA Target (%)</label>
									<select id="sla_target" name="sla_target" class="form-select">
										<option value="0" if p.Monitor.SLATarget == 0 { selected }>None</option>
										<option value="99" if p.Monitor.SLATarget == 99 { selected }>99%</option>
										<option value="99.5" if p.Monitor.SLATarget == 99.5 { selected }>99.5%</option>
										<option value="99.9" if p.Monitor.SLATarget == 99.9 { selected }>99.9%</option>
										<option value="99.95" if p.Monitor.SLATarget == 99.95 { selected }>99.95%</option>
										<option value="99.99" if p.Monitor.SLATarget == 99.99 { selected }>99.99%</option>
									</select>
								</div>
								<div>
									<label class="form-label" for="anomaly_sensitivity">Anomaly Detection</label>
									<select id="anomaly_sensitivity" name="anomaly_sensitivity" class="form-select">
										<option value="off" if p.Monitor.AnomalySensitivity == "" || p.Monitor.AnomalySensitivity == "off" { selected }>Off</option>
										<option value="low" if p.Monitor.AnomalySensitivity == "low" { selected }>Low (3 sigma)</option>
										<option value="medium" if p.Monitor.AnomalySensitivity == "medium" { selected }>Medium (2 sigma)</option>
										<option value="high" if p.Monitor.AnomalySensitivity == "high" { selected }>High (1.5 sigma)</option>
									</select>
									<p class="text-2xs text-muted mt-1">Mark as degraded when response time exceeds the rolling baseline</p>
								</div>
								<div>
									<label class="form-label" for="resend_interval">Resend Notification Interval (s)</label>
									<input id="resend_interval" type="number" name="resend_interval" value={ fmt.Sprint(p.Monitor.ResendInterval) } min="0" placeholder="0 = disabled" class="form-input max-w-[200px] tabular-nums"/>
									<p class="text-2xs text-muted mt-1">Resend notification every N seconds while down (0 = disabled)</p>
								</div>
								<div class="flex items-center flex-wrap gap-5">
									@SettingCheckbox("Track changes", "track_changes", p.Monitor.TrackChanges)
									@SettingCheckbox("Upside-down mode", "upside_down", p.Monitor.UpsideDown)
									@SettingCheckbox("Enable for agents", "agent_enabled", p.Monitor.AgentEnabled)
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="sticky bottom-0 inset-x-0 z-10 flex items-center gap-3 -mx-5 px-5 py-3 mt-2 border-t border-line bg-surface/95 backdrop-blur md:static md:mx-0 md:px-0 md:py-0 md:border-0 md:bg-transparent md:backdrop-blur-none">
					<button type="submit" class="btn-primary btn-press focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50">
						if p.Monitor.ID != 0 {
							Update
						} else {
							Create
						}
					</button>
					<a
						if p.Monitor.ID != 0 {
							href={ templ.SafeURL(fmt.Sprintf("%s/monitors/%d", p.BasePath, p.Monitor.ID)) }
						} else {
							href={ templ.SafeURL(p.BasePath + "/monitors") }
						}
						class="btn-secondary btn-press focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50">Cancel</a>
				</div>
			</form>
		</div>
	}
}

templ monitorHTTPSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'http'" x-cloak class="space-y-4">
		<div class="grid grid-cols-2 gap-4">
			<div>
				<label class="form-label" for="settings_method">Method</label>
				<select id="settings_method" name="settings_method" x-model="httpMethod" class="form-select">
					<option value="GET">GET</option>
					<option value="POST">POST</option>
					<option value="PUT">PUT</option>
					<option value="PATCH">PATCH</option>
					<option value="DELETE">DELETE</option>
					<option value="HEAD">HEAD</option>
					<option value="OPTIONS">OPTIONS</option>
				</select>
			</div>
			<div>
				<label class="form-label" for="settings_expected_status">Expected Status</label>
				<input id="settings_expected_status" type="number" name="settings_expected_status"
					if p.HTTP.ExpectedStatus != 0 {
						value={ fmt.Sprint(p.HTTP.ExpectedStatus) }
					}
					placeholder="200" class="form-input tabular-nums"/>
			</div>
		</div>
		<div x-show="httpMethod === 'POST' || httpMethod === 'PUT' || httpMethod === 'PATCH'" x-cloak class="space-y-4">
			<div>
				<label class="form-label" for="settings_body_encoding">Body Encoding</label>
				<select id="settings_body_encoding" name="settings_body_encoding" class="form-select">
					<option value="json" selected?={ p.HTTP.BodyEncoding == "json" }>JSON</option>
					<option value="xml" selected?={ p.HTTP.BodyEncoding == "xml" }>XML</option>
					<option value="form" selected?={ p.HTTP.BodyEncoding == "form" }>Form</option>
					<option value="raw" selected?={ p.HTTP.BodyEncoding == "raw" }>Raw</option>
				</select>
			</div>
			<div>
				<label class="form-label" for="settings_body">Body</label>
				<textarea id="settings_body" name="settings_body" rows="3" placeholder="Request body" class="form-input font-mono resize-y">{ p.HTTP.Body }</textarea>
			</div>
		</div>
		@HeaderListEditor("httpHeaders", "settings_header_key[]", "settings_header_value[]")
		<div class="space-y-3">
			<div>
				<label class="form-label" for="settings_auth_method">Authentication</label>
				<select id="settings_auth_method" name="settings_auth_method" x-model="authMethod" class="form-select">
					<option value="none">None</option>
					<option value="basic">Basic Auth</option>
					<option value="bearer">Bearer Token</option>
					<option value="oauth2">OAuth2 Client Credentials</option>
				</select>
			</div>
			<div x-show="authMethod === 'basic'" x-cloak class="grid grid-cols-2 gap-4">
				@SettingText("Username", "settings_basic_auth_user", p.HTTP.BasicAuthUser, "", "text")
				@SettingPassword("Password", "settings_basic_auth_pass", p.HTTP.BasicAuthPass, "")
			</div>
			<div x-show="authMethod === 'bearer'" x-cloak>
				@SettingPassword("Token", "settings_bearer_token", p.HTTP.BearerToken, "")
			</div>
			<div x-show="authMethod === 'oauth2'" x-cloak class="space-y-3">
				@SettingText("Token URL", "settings_oauth2_token_url", p.HTTP.OAuth2TokenURL, "https://auth.example.com/oauth/token", "url")
				<div class="grid grid-cols-2 gap-4">
					@SettingText("Client ID", "settings_oauth2_client_id", p.HTTP.OAuth2ClientID, "", "text")
					@SettingPassword("Client Secret", "settings_oauth2_client_secret", p.HTTP.OAuth2ClientSecret, "")
				</div>
				<div class="grid grid-cols-2 gap-4">
					<div>
						<label class="form-label" for="settings_oauth2_scopes">Scopes <span class="text-muted font-normal">(optional)</span></label>
						<input id="settings_oauth2_scopes" type="text" name="settings_oauth2_scopes" value={ p.HTTP.OAuth2Scopes } placeholder="read write" class="form-input"/>
					</div>
					<div>
						<label class="form-label" for="settings_oauth2_audience">Audience <span class="text-muted font-normal">(optional)</span></label>
						<input id="settings_oauth2_audience" type="text" name="settings_oauth2_audience" value={ p.HTTP.OAuth2Audience } placeholder="https://api.example.com" class="form-input"/>
					</div>
				</div>
			</div>
		</div>
		<div class="space-y-3">
			<label class="flex items-center gap-2 cursor-pointer">
				<input type="checkbox" name="settings_mtls_enabled" x-model="mtlsEnabled"
					if p.HTTP.MTLSEnabled {
						checked
					}
					class="form-checkbox"/>
				<span class="text-xs text-muted-light">Mutual TLS (mTLS)</span>
			</label>
			<div x-show="mtlsEnabled" x-cloak class="space-y-3">
				<div>
					<label class="form-label" for="settings_mtls_client_cert">Client Certificate <span class="text-muted font-normal">(PEM)</span></label>
					<textarea id="settings_mtls_client_cert" name="settings_mtls_client_cert" rows="4" placeholder="-----BEGIN CERTIFICATE-----" class="form-input font-mono text-xs resize-y">{ p.HTTP.MTLSClientCert }</textarea>
				</div>
				<div>
					<label class="form-label" for="settings_mtls_client_key">Client Key <span class="text-muted font-normal">(PEM)</span></label>
					<textarea id="settings_mtls_client_key" name="settings_mtls_client_key" rows="4" placeholder="-----BEGIN PRIVATE KEY-----" class="form-input font-mono text-xs resize-y">{ p.HTTP.MTLSClientKey }</textarea>
				</div>
				<div>
					<label class="form-label" for="settings_mtls_ca_cert">CA Certificate <span class="text-muted font-normal">(optional, PEM)</span></label>
					<textarea id="settings_mtls_ca_cert" name="settings_mtls_ca_cert" rows="3" placeholder="-----BEGIN CERTIFICATE-----" class="form-input font-mono text-xs resize-y">{ p.HTTP.MTLSCACert }</textarea>
					<p class="text-2xs text-muted mt-1">Custom CA for self-signed server certificates</p>
				</div>
			</div>
		</div>
		<div>
			<label class="form-label" for="settings_max_redirects">Max Redirects</label>
			<input id="settings_max_redirects" type="number" name="settings_max_redirects" value={ fmt.Sprint(p.MaxRedirects) } min="0" max="30" class="form-input max-w-[200px] tabular-nums"/>
			<p class="text-2xs text-muted mt-1">0 = don't follow redirects</p>
		</div>
		<div class="flex items-center flex-wrap gap-5">
			@SettingCheckbox("Ignore TLS/SSL errors", "settings_skip_tls_verify", p.HTTP.SkipTLSVerify)
			@SettingCheckbox("Cache buster", "settings_cache_buster", p.HTTP.CacheBuster)
		</div>
	</div>
}

templ monitorTCPSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'tcp'" x-cloak class="space-y-4">
		@SettingText("Send Data", "settings_send_data", p.TCP.SendData, "Optional data to send", "text")
		@SettingText("Expect Data", "settings_expect_data", p.TCP.ExpectData, "Expected response", "text")
	</div>
}

templ monitorDNSSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'dns'" x-cloak class="space-y-4">
		<div class="grid grid-cols-2 gap-4">
			<div>
				<label class="form-label" for="settings_record_type">Record Type</label>
				<select id="settings_record_type" name="settings_record_type" class="form-select">
					<option value="A" selected?={ p.DNS.RecordType == "A" }>A</option>
					<option value="AAAA" selected?={ p.DNS.RecordType == "AAAA" }>AAAA</option>
					<option value="CNAME" selected?={ p.DNS.RecordType == "CNAME" }>CNAME</option>
					<option value="MX" selected?={ p.DNS.RecordType == "MX" }>MX</option>
					<option value="TXT" selected?={ p.DNS.RecordType == "TXT" }>TXT</option>
					<option value="NS" selected?={ p.DNS.RecordType == "NS" }>NS</option>
					<option value="SOA" selected?={ p.DNS.RecordType == "SOA" }>SOA</option>
				</select>
			</div>
			<div>
				<label class="form-label" for="settings_dns_server">DNS Server</label>
				<input id="settings_dns_server" type="text" name="settings_dns_server" value={ p.DNS.Server } placeholder="Optional (e.g. 8.8.8.8)" class="form-input"/>
			</div>
		</div>
	</div>
}

templ monitorTLSSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'tls'" x-cloak class="space-y-4">
		@SettingNumber("Warning Days Before Expiry", "settings_warn_days_before", intOrDefault(p.TLS.WarnDaysBefore, 30), "", "1", "365", "max-w-[200px]")
	</div>
}

templ monitorWSSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'websocket'" x-cloak class="space-y-4">
		@HeaderListEditor("wsHeaders", "settings_ws_header_key[]", "settings_ws_header_value[]")
		@SettingText("Send Message", "settings_send_message", p.WS.SendMessage, "Optional message to send", "text")
		@SettingText("Expect Reply", "settings_expect_reply", p.WS.ExpectReply, "Expected reply", "text")
	</div>
}

templ monitorCommandSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'command'" x-cloak class="space-y-4">
		@SettingText("Command", "settings_command", p.Cmd.Command, "/usr/bin/check-health", "text")
		<div>
			<label class="form-label" for="settings_args">Arguments</label>
			<input id="settings_args" type="text" name="settings_args" value={ p.cmdArgsStr() } placeholder="--verbose, --timeout=5" class="form-input"/>
			<p class="text-2xs text-muted mt-1">Comma-separated</p>
		</div>
	</div>
}

templ monitorDockerSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'docker'" x-cloak class="space-y-4">
		<div>
			<label class="form-label" for="settings_container_name">Container Name / ID</label>
			<input id="settings_container_name" type="text" name="settings_container_name" value={ p.Docker.ContainerName } placeholder="my-container or abc123def" class="form-input"/>
			<p class="text-2xs text-muted mt-1">Overrides target if set</p>
		</div>
		<div>
			<label class="form-label" for="settings_socket_path">Docker Socket Path</label>
			<input id="settings_socket_path" type="text" name="settings_socket_path" value={ p.Docker.SocketPath } placeholder="/var/run/docker.sock" class="form-input"/>
			<p class="text-2xs text-muted mt-1">Default: /var/run/docker.sock</p>
		</div>
		<div class="flex items-center flex-wrap gap-5">
			@SettingCheckbox("Check container health status", "settings_check_health", p.Docker.CheckHealth)
		</div>
	</div>
}

templ monitorDomainSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'domain'" x-cloak class="space-y-4">
		<div>
			<label class="form-label" for="settings_domain_warn_days">Warning Days Before Expiry</label>
			<input id="settings_domain_warn_days" type="number" name="settings_domain_warn_days" value={ intOrDefault(p.Domain.WarnDaysBefore, 30) } min="1" max="365" class="form-input max-w-[200px] tabular-nums"/>
			<p class="text-2xs text-muted mt-1">Mark as degraded when domain expires within this many days</p>
		</div>
	</div>
}

templ monitorGRPCSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'grpc'" x-cloak class="space-y-4">
		<div>
			<label class="form-label" for="settings_grpc_service">Service Name</label>
			<input id="settings_grpc_service" type="text" name="settings_grpc_service" value={ p.GRPC.ServiceName } placeholder="Leave empty for overall health" class="form-input"/>
			<p class="text-2xs text-muted mt-1">gRPC service to check (empty = all services)</p>
		</div>
		<div class="flex items-center flex-wrap gap-5">
			@SettingCheckbox("Use TLS", "settings_grpc_tls", p.GRPC.UseTLS)
			@SettingCheckbox("Skip TLS verification", "settings_grpc_skip_verify", p.GRPC.SkipTLSVerify)
		</div>
	</div>
}

templ monitorMQTTSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'mqtt'" x-cloak class="space-y-4">
		<div class="grid grid-cols-2 gap-4">
			@SettingText("Client ID", "settings_mqtt_client_id", p.MQTT.ClientID, "asura-monitor", "text")
			@SettingText("Topic", "settings_mqtt_topic", p.MQTT.Topic, "Optional subscribe topic", "text")
		</div>
		<div class="grid grid-cols-2 gap-4">
			@SettingText("Username", "settings_mqtt_username", p.MQTT.Username, "Optional", "text")
			@SettingPassword("Password", "settings_mqtt_password", p.MQTT.Password, "Optional")
		</div>
		@SettingText("Expected Message", "settings_mqtt_expect", p.MQTT.ExpectMessage, "Optional message content to expect", "text")
		<div class="flex items-center flex-wrap gap-5">
			@SettingCheckbox("Use TLS", "settings_mqtt_tls", p.MQTT.UseTLS)
		</div>
	</div>
}

templ monitorAssertions(p MonitorFormParams) {
	<div class="card card-pad">
		<div class="flex items-center justify-between mb-4">
			<h2 class="text-sm font-semibold text-white">Conditions</h2>
			<button type="button" x-show="conditions.groups.length > 0 || advancedAssertions" @click="advancedAssertions = !advancedAssertions" class="text-2xs text-brand hover:text-brand/80 transition-colors rounded-control px-1 py-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50">
				<span x-text="advancedAssertions ? 'Form Mode' : 'Advanced (JSON)'"></span>
			</button>
		</div>
		<input type="hidden" name="assertions_mode" :value="advancedAssertions ? 'json' : 'form'"/>
		<div x-show="advancedAssertions" x-cloak>
			<textarea name="assertions_json" rows="8" placeholder="{}" class="form-input font-mono text-xs resize-y">{ p.AssertionsRaw }</textarea>
		</div>
		<div x-show="!advancedAssertions">
			<input type="hidden" name="group_count" :value="conditions.groups.length"/>
			<input type="hidden" name="condition_set_operator" :value="conditions.operator"/>
			<div x-show="conditions.groups.length === 0" class="flex flex-col items-center gap-3 text-center">
				<div class="px-4 py-10 text-center text-xs text-muted">No conditions yet</div>
				<button type="button" @click="addGroup()" class="btn-secondary btn-sm btn-press focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50">+ Add Group</button>
			</div>
			<div class="space-y-1">
				<template x-for="(g, gi) in conditions.groups" :key="gi">
					<div>
						<!-- AND/OR connector between groups -->
						<div x-show="gi > 0" class="flex items-center gap-2 my-2">
							<div class="flex-1 border-t border-line/30"></div>
							<select x-model="conditions.operator" class="form-select py-0.5 px-2 text-2xs font-medium w-20">
								<option value="and">AND</option>
								<option value="or">OR</option>
							</select>
							<div class="flex-1 border-t border-line/30"></div>
						</div>
						<!-- Per-group hidden structural inputs -->
						<input type="hidden" :name="'group_' + gi + '_operator'" :value="g.operator"/>
						<input type="hidden" :name="'group_' + gi + '_count'" :value="g.conditions.length"/>
						<div class="panel overflow-hidden">
							<div class="flex items-center justify-between px-3 py-2 bg-surface-200/40 border-b border-line/40">
								<div class="flex items-center gap-2">
									<span class="text-2xs text-muted">Match</span>
									<select x-model="g.operator" class="form-select py-0.5 px-2 text-2xs font-medium w-20">
										<option value="and">ALL</option>
										<option value="or">ANY</option>
									</select>
									<span class="text-2xs text-muted">conditions</span>
								</div>
								<button type="button" @click="conditions.groups.splice(gi, 1)" class="row-action hover:text-red-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50" title="Remove group" aria-label="Remove group">
									<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
								</button>
							</div>
							<div class="p-3 space-y-2">
								<template x-for="(c, ci) in g.conditions" :key="ci">
									<div class="flex items-start gap-2">
										<div class="flex-1 grid grid-cols-2 gap-1.5">
											<select :name="'group_' + gi + '_type_' + ci" x-model="c.type" class="form-select py-1.5 text-xs">
												<option value="status_code">Status Code</option>
												<option value="body_contains">Body Contains</option>
												<option value="body_regex">Body Regex</option>
												<option value="json_path">JSON Path</option>
												<option value="header">Header</option>
												<option value="response_time">Response Time (ms)</option>
												<option value="cert_expiry">Cert Expiry (days)</option>
												<option value="dns_record">DNS Record</option>
											</select>
											<select :name="'group_' + gi + '_operator_' + ci" x-model="c.operator" class="form-select py-1.5 text-xs">
												<template x-for="op in operatorsFor(c.type)" :key="op[0]">
													<option :value="op[0]" x-text="op[1]"></option>
												</template>
											</select>
											<div x-show="needsTarget(c.type)">
												<input type="text" :name="'group_' + gi + '_target_' + ci" x-model="c.target" placeholder="Header name or JSON path" class="form-input py-1.5 text-xs"/>
											</div>
											<div x-show="needsValue(c.operator)" :class="needsTarget(c.type) ? '' : 'col-span-2'">
												<input type="text" :name="'group_' + gi + '_value_' + ci" x-model="c.value" placeholder="Expected value" class="form-input py-1.5 text-xs"/>
											</div>
										</div>
										<div class="flex items-center gap-2 pt-1.5 shrink-0">
											<label class="flex items-center gap-1 cursor-pointer" title="Soft: mark as degraded instead of down">
												<input type="checkbox" :name="'group_' + gi + '_degraded_' + ci" value="on" :checked="c.degraded" @change="c.degraded = $event.target.checked" class="form-checkbox w-3 h-3"/>
												<span class="text-2xs text-muted">soft</span>
											</label>
											<button type="button" @click="g.conditions.splice(ci, 1)" class="row-action hover:text-red-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50" title="Remove condition" aria-label="Remove condition">
												<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
											</button>
										</div>
									</div>
								</template>
								<button type="button" @click="g.conditions.push(newCond())" class="text-xs text-brand hover:text-brand/80 transition-colors rounded-control px-1 py-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50">+ Add Condition</button>
							</div>
						</div>
					</div>
				</template>
			</div>
			<button type="button" x-show="conditions.groups.length > 0" @click="addGroup()" class="mt-3 text-xs text-brand hover:text-brand/80 transition-colors rounded-control px-1 py-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50">+ Add Group</button>
		</div>
	</div>
}

templ monitorSMTPSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'smtp'" x-cloak class="space-y-4">
		<div class="grid grid-cols-2 gap-4">
			<div>
				<label class="form-label" for="settings_smtp_port">Port</label>
				<input id="settings_smtp_port" type="number" name="settings_smtp_port"
					if p.SMTP.Port != 0 {
						value={ fmt.Sprint(p.SMTP.Port) }
					}
					placeholder="25" min="1" max="65535" class="form-input tabular-nums"/>
				<p class="text-2xs text-muted mt-1">25 (plain), 465 (SMTPS), 587 (submission)</p>
			</div>
			<div>
				<label class="form-label" for="settings_smtp_expect_banner">Expected Banner</label>
				<input id="settings_smtp_expect_banner" type="text" name="settings_smtp_expect_banner" value={ p.SMTP.ExpectBanner } placeholder="Optional" class="form-input"/>
			</div>
		</div>
		@SettingCheckbox("Require STARTTLS", "settings_smtp_starttls", p.SMTP.STARTTLS)
	</div>
}

templ monitorSSHSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'ssh'" x-cloak class="space-y-4">
		<div>
			<label class="form-label" for="settings_ssh_fingerprint">Expected Host Key Fingerprint</label>
			<input id="settings_ssh_fingerprint" type="text" name="settings_ssh_fingerprint" value={ p.SSH.ExpectedFingerprint } placeholder="Optional SHA-256 hex fingerprint" class="form-input font-mono"/>
			<p class="text-2xs text-muted mt-1">Leave empty to accept any host key</p>
		</div>
	</div>
}

templ monitorRedisSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'redis'" x-cloak class="space-y-4">
		@SettingPassword("Password", "settings_redis_password", p.Redis.Password, "Optional")
	</div>
}

templ monitorPostgreSQLSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'postgresql'" x-cloak class="space-y-4">
		<div class="grid grid-cols-2 gap-4">
			@SettingText("Username", "settings_pg_username", p.PostgreSQL.Username, "postgres", "text")
			@SettingText("Database", "settings_pg_database", p.PostgreSQL.Database, "postgres", "text")
		</div>
		<p class="text-2xs text-muted">Checks if PostgreSQL accepts connections (startup handshake). No authentication performed.</p>
	</div>
}

templ monitorUDPSettings(p MonitorFormParams) {
	<div x-show="monitorType === 'udp'" x-cloak class="space-y-4">
		@SettingText("Send Data", "settings_udp_send", p.UDP.SendData, "Data to send", "text")
		@SettingText("Expect Data", "settings_udp_expect", p.UDP.ExpectData, "Expected in response (optional)", "text")
	</div>
}
